# CATalyst AI — Express Backend Environment Variables
# Copy to .env and fill in values

PORT=5000
DATABASE_URL=postgresql://user:password@host:5432/catalyst_db?sslmode=require
JWT_SECRET=your-jwt-secret-here
NODE_ENV=development

# FastAPI Python backend URL (no trailing slash)
# Local dev:   http://localhost:8000
# Production:  https://catalyst-ai-python.onrender.com
PYTHON_BACKEND_URL=http://localhost:8000

# Frontend URL (for CORS, no trailing slash)
# Local dev:   http://localhost:5173
# Production:  https://catalyst-ai-frontend.onrender.com
FRONTEND_URL=http://localhost:5173
