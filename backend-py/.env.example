# CATalyst AI — FastAPI Backend Environment Variables
# Copy to .env and fill in values

# PostgreSQL vector database connection (asyncpg format)
VECTOR_DB_URL=postgresql://user:password@host:5432/catalyst_vectors?sslmode=require

# Prisma database (same or separate from vector DB)
DATABASE_URL=postgresql://user:password@host:5432/catalyst_db?sslmode=require

# Groq LLM API key (https://console.groq.com/keys)
GROQ_API_KEY=gsk_your_key_here

# JWT secret (must match Express backend)
JWT_SECRET=your-jwt-secret-here

# LLM parameters
LLM_TEMPERATURE=0.7
LLM_TOP_P=0.9
LLM_MAX_TOKENS=2048

# CORS origins (for Render deployment)
FRONTEND_URL=http://localhost:5173
EXPRESS_BACKEND_URL=http://localhost:5000
